# Langfuse local self-hosted defaults for development.
# scripts/langfuse-up.sh copies this file to .env on first run.

# --- Postgres ---
POSTGRES_USER=langfuse
POSTGRES_PASSWORD=langfuse-pg-local-2026
POSTGRES_DB=langfuse

# --- ClickHouse ---
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=langfuse-ch-local-2026
CLICKHOUSE_MIGRATION_URL=clickhouse://clickhouse:9000
CLICKHOUSE_URL=http://clickhouse:8123

# --- Redis ---
REDIS_AUTH=langfuse-redis-local-2026

# --- MinIO / S3 ---
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=langfuse-minio-local-2026
LANGFUSE_S3_EVENT_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_EVENT_UPLOAD_REGION=auto
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=langfuse-minio-local-2026
LANGFUSE_S3_EVENT_UPLOAD_ENDPOINT=http://minio:9000
LANGFUSE_S3_EVENT_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_MEDIA_UPLOAD_BUCKET=langfuse
LANGFUSE_S3_MEDIA_UPLOAD_REGION=auto
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=minio
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=langfuse-minio-local-2026
LANGFUSE_S3_MEDIA_UPLOAD_ENDPOINT=http://localhost:9090
LANGFUSE_S3_MEDIA_UPLOAD_FORCE_PATH_STYLE=true
LANGFUSE_S3_BATCH_EXPORT_BUCKET=langfuse
LANGFUSE_S3_BATCH_EXPORT_REGION=auto
LANGFUSE_S3_BATCH_EXPORT_ENDPOINT=http://minio:9000
LANGFUSE_S3_BATCH_EXPORT_EXTERNAL_ENDPOINT=http://localhost:9090
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=minio
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=langfuse-minio-local-2026
LANGFUSE_S3_BATCH_EXPORT_FORCE_PATH_STYLE=true

# --- Langfuse application secrets ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=5e9bbebbb9734a59816fe6a91d8131b711d13c6f95f824fe6f4259f6233810f5
SALT=157521c8de7975b33c5e83a4a80b34d08c84c0b82a08832f6886610f583df070
ENCRYPTION_KEY=69155a2eaa3bf5cd364e68b5d9052a82774776863382bc89b6f7eb882139f4c9
TELEMETRY_ENABLED=false
LANGFUSE_ENABLE_EXPERIMENTAL_FEATURES=false
LANGFUSE_USE_AZURE_BLOB=false
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_TLS_ENABLED=false

# --- Auto-provision local org / project / user / API keys ---
LANGFUSE_INIT_ORG_ID=mad-efficiency-factory
LANGFUSE_INIT_ORG_NAME=Mad Efficiency Factory
LANGFUSE_INIT_PROJECT_ID=claude-code-traces
LANGFUSE_INIT_PROJECT_NAME=Claude Code Traces
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=pk-lf-local-dev
LANGFUSE_INIT_PROJECT_SECRET_KEY=sk-lf-local-dev
LANGFUSE_INIT_USER_EMAIL=admin@local.dev
LANGFUSE_INIT_USER_NAME=Admin
LANGFUSE_INIT_USER_PASSWORD=changeme-admin-password
